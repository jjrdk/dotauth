@using System.Linq
@model DotAuth.ViewModels.AuthorizeOpenIdViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Authenticate";
    var loginState = ViewData.ModelState["Login"];
    var passwordState = ViewData.ModelState["Password"];
    var localModel = Model as DotAuth.ViewModels.OpenidLocalAuthenticationViewModel;
}

<div class="row">
    <div class="col s12 m6 offset-m3">
        @if (Model.IdProviders.Any())
        {
            <div class="col s12">
                <div class="card">
                    <div class="card-content">
                        <h5>Log in with your external account</h5>
                    </div>
                    <div class="card-action">
                        <form method="post" action="@Url.AuthenticateExternalLoginOpenIdPath(Model.Code!)">
                            @Html.AntiForgeryToken()
                            @foreach (var loginProvider in Model.IdProviders)
                            {
                                <button type="submit" class="waves-effect waves-light btn blue darken-3" id="@loginProvider.DisplayName" name="provider" value="@loginProvider.DisplayName" title="Log in using your @loginProvider.DisplayName account">@loginProvider.DisplayName</button>
                            }
                        </form>
                    </div>
                </div>
            </div>
        }

        <div class="col s12">
            <div class="card">
                <div class="card-content">
                    <h5>Log in with your local account</h5>
                </div>
                <div class="card-action">
                    <div class="col s12">@Html.ValidationMessage("invalid_credentials")</div>
                    <form class="col s12" name="form" method="post" action="@Url.AuthenticateLocalLoginOpenIdPath()">
                        @Html.AntiForgeryToken()
                        <input type="hidden" value="@Model.Code" name="Code" />
                        <div class="row">
                            <div class="input-field col s12">
                                <i class="material-icons prefix">account_circle</i>
                                <input id="Login" name="Login" type="text" value="@localModel?.Login" class="@(loginState != null && loginState.Errors.Any() ? "invalid" : null)" />
                                <label for="Login">Username</label>
                                @if (loginState != null && loginState.Errors.Any())
                                {
                                    <span class="helper-text">@string.Join(",", loginState.Errors.Select(e => e.ErrorMessage))</span>
                                }
                            </div>

                            <div class="input-field col s12">
                                <i class="material-icons prefix">lock</i>
                                <input id="Password" name="Password" type="password" class="@(passwordState != null && passwordState.Errors.Any() ? "invalid" : null)" />
                                <label for="Password">Password</label>
                                @if (passwordState != null && passwordState.Errors.Any())
                                {
                                    <span class="helper-text">@string.Join(",", passwordState.Errors.Select(e => e.ErrorMessage))</span>
                                }
                            </div>
                        </div>
                        <div class="col s12 m6">
                            <button type="submit" class="waves-effect waves-light btn blue darken-3 right">Log In</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
