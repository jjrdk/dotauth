@{
    ViewBag.Title = DotAuth.Extensions.Globals.ApplicationName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col s12">
        <div class="card">
            <div class="card-content">
                <div class="center-align">
                    <h1>@DotAuth.Extensions.Globals.ApplicationName</h1>
                    <div class="flow-text grey-text text-darken-1">modern identity for connected applications</div>
                </div>
                <div class="m12">
                    @DotAuth.Extensions.Globals.ApplicationName is an open-source, cloud-friendly authorization server for teams building secure apps and APIs with OpenID Connect, OAuth2, and UMA. Manage clients, users, scopes, permissions, and consent from one streamlined control plane.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row dashboard-card-row">
    <div class="col s6 m4 dashboard-card-col">
        <div class="card dashboard-card">
            <div class="card-image">
                <img alt="Manage UMA Resources" src="~/img/manage_resources.png" />
            </div>
            <div class="card-content">
                <span class="card-title">Manage UMA Resources</span>
                <p>Create and organize protected resources, then define which scopes can be requested for each one.</p>
            </div>
            <div class="card-action center">
                <a href="@Url.ResourceSetPath(includeUiQuery: true)" class="btn blue darken-3 waves-effect waves-light">Manage UMA Resources</a>
            </div>
        </div>
    </div>
    <div class="col s6 m4 dashboard-card-col">
        <div class="card dashboard-card">
            <div class="card-image">
                <img alt="Manage Permission Requests" src="~/img/manage_permissions.png" />
            </div>
            <div class="card-content">
                <span class="card-title">Manage Permission Requests</span>
                <p>Review incoming access requests and approve or deny permissions for shared resources.</p>
            </div>
            <div class="card-action center">
                <a href="@Url.PermissionRequestsPath()" class="btn blue darken-3 waves-effect waves-light">Manage Permission Requests</a>
            </div>
        </div>
    </div>
    <div class="col s6 m4 dashboard-card-col">
        <div class="card dashboard-card">
            <div class="card-image">
                <img alt="Manage Consents" src="~/img/manage_consent.png" />
            </div>
            <div class="card-content">
                <span class="card-title">Manage Consents</span>
                <p>See which applications can access your data and revoke consents you no longer trust.</p>
            </div>
            <div class="card-action center">
                <a href="@Url.UserConsentPath()" class="btn blue darken-3 waves-effect waves-light">Manage Consents</a>
            </div>
        </div>
    </div>
</div>

@if (User.Claims.Any(c => c.Type == "role" && c.Value.Contains("administrator")))
{
    <div class="row dashboard-card-row">
        <div class="col s6 m4 dashboard-card-col">
            <div class="card dashboard-card">
                <div class="card-image">
                    <img alt="Register Client" src="~/img/manage_resources.png" />
                </div>
                <div class="card-content">
                    <span class="card-title">Register Client</span>
                    <p>Add OAuth/OpenID client applications, configure redirect URIs, and choose allowed grant types.</p>
                </div>
                <div class="card-action center">
                    <a href="@Url.ClientCreatePath()" class="btn blue darken-3 waves-effect waves-light">Register Client</a>
                </div>
            </div>
        </div>
        <div class="col s6 m4 dashboard-card-col">
            <div class="card dashboard-card">
                <div class="card-image">
                    <img alt="Manage Users" src="~/img/manage_users.png"/>
                </div>
                <div class="card-content">
                    <span class="card-title">Manage Users</span>
                    <p>View user accounts, update profile claims, and maintain access-related account settings.</p>
                </div>
                <div class="card-action center">
                    <a href="@Url.ResourceOwnersPath()" class="btn blue darken-3 waves-effect waves-light">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col s6 m4 dashboard-card-col">
            <div class="card dashboard-card">
                <div class="card-image">
                    <img alt="Manage Scopes" src="~/img/manage_scopes.png"/>
                </div>
                <div class="card-content">
                    <span class="card-title">Manage Scopes</span>
                    <p>Define API scopes and control which permissions are available to clients and users.</p>
                </div>
                <div class="card-action center">
                    <a href="@Url.ScopesPath()" class="btn blue darken-3 waves-effect waves-light">Manage Scopes</a>
                </div>
            </div>
        </div>
    </div>
}
